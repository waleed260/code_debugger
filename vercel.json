{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "api_v2/server.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/v2/ws/.*",
      "dest": "api_v2/server.py"
    },
    {
      "src": "/v2/(.*)",
      "dest": "api_v2/server.py"
    },
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ]
}
